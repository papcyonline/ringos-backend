generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum CompanionMode {
  CALM_LISTENER
  LIGHT_AND_FUN
  NIGHT_COMPANION
  MOTIVATOR
  RELATIONSHIP_COACH
  CAREER_MENTOR
}

enum MatchIntent {
  VENT
  CASUAL_CHAT
  DEEP_TALK
  ADVICE
  JUST_LISTEN
}

enum MoodTag {
  HAPPY
  SAD
  ANXIOUS
  LONELY
  ANGRY
  NEUTRAL
  EXCITED
  TIRED
  OVERWHELMED
  HOPEFUL
}

enum ConversationType {
  HUMAN_MATCHED
  AI_HANDOFF
  GROUP
}

enum ParticipantRole {
  ADMIN
  MEMBER
}

enum CallType {
  AUDIO
  VIDEO
}

enum CallLogStatus {
  COMPLETED
  MISSED
  REJECTED
}

enum MatchRequestStatus {
  WAITING
  MATCHED
  EXPIRED
  CANCELLED
}

enum ConversationStatus {
  ACTIVE
  ENDED
}

// Per-user inbox gating. Controls whether a stranger (someone the
// recipient does not follow) can land a direct message at all, and
// whether their first message gets queued for review.
//   EVERYONE  — anyone can DM. Strangers' first message is queued in
//               Requests (no push) until the recipient accepts.
//   FOLLOWING — only people the recipient follows can DM. Others get
//               a polite rejection at send time (no queue).
//   NOBODY    — DMs are off entirely.
enum MessagePrivacy {
  EVERYONE
  FOLLOWING
  NOBODY
}

// Lifecycle of a "message request" — a direct conversation initiated
// by someone the recipient doesn't follow. NULL on the Conversation
// row means "not a request" (existing convos, groups, mutuals).
enum ConversationRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum AiSessionStatus {
  ACTIVE
  ENDED
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ReportReason {
  HARASSMENT
  SPAM
  INAPPROPRIATE_CONTENT
  SELF_HARM
  THREATS
  SCAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum StorySlideType {
  IMAGE
  VIDEO
  TEXT
}

enum BanStatus {
  NONE
  WARNING
  TEMP_BAN
  PERMANENT_BAN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
  PHONE
  ANONYMOUS
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum NotificationType {
  CHAT_MESSAGE
  VOICE_NOTE
  NEW_FOLLOWER
  PROFILE_LIKED
  MATCH_FOUND
  STORY_GIFT
  STORY_LIKED
  STORY_VIEWED
  STORY_MILESTONE
  MISSED_CALL
  SYSTEM
  POST_LIKED
  POST_COMMENTED
  POST_MENTION
  NEW_POST
  NEW_STORY
  MESSAGE_REQUESTS_DIGEST
  NEW_FOLLOWERS_DIGEST
  ADDED_TO_GROUP
}

enum TransactionType {
  PURCHASE
  GIFT
  TIP
}

enum ReEngagementHook {
  UNREAD_DM
  NEW_FOLLOWER
  FOLLOWED_STORY
  NEW_JOINS
  GENERIC
}

// ─── Models ─────────────────────────────────────────────

model User {
  id            String       @id @default(uuid())
  email         String?      @unique
  passwordHash  String?
  googleId      String?      @unique
  appleId       String?      @unique
  authProvider  AuthProvider @default(EMAIL)
  deviceId      String?      @unique
  phoneHash     String?      @unique
  phoneLookup   String?      @unique
  displayName       String
  lastNameChangeAt  DateTime?
  avatarUrl     String?
  coverUrl      String?
  bio           String?
  profession    String?
  gender        Gender?
  location      String?
  // Profile links shown to other users as tappable pill buttons.
  // Array of { type: 'website'|'email'|'phone'|'instagram'|'x'|'facebook'
  //            |'linkedin'|'tiktok', label: string, value: string }.
  // JSONB so the set stays flexible without per-type columns.
  profileLinks  Json?
  // Required for COPPA / GDPR-K compliance + App Store age-gating.
  // Stored as DateTime so age can be computed precisely; nullable so
  // existing users without DOB don't break (they're prompted on next
  // launch via isProfileComplete()).
  dateOfBirth   DateTime?
  // Highest version of the legal docs (Terms / Privacy / Community Guidelines)
  // this user has accepted. Compared against the backend's current version to
  // decide when to re-prompt for consent. History lives in LegalConsent.
  acceptedLegalVersion Int?
  legalConsents LegalConsent[]
  status        String    @default("available")
  availabilityNote String?
  // Who can DM this user. See MessagePrivacy enum for semantics.
  messagePrivacy MessagePrivacy @default(EVERYONE)
  isAnonymous   Boolean   @default(true)
  isOnline      Boolean   @default(false)
  lastSeenAt    DateTime?
  // When the user last opened their own followers list. Used so the
  // "new followers" push digest only counts followers gained since they
  // actually looked — not everyone from the last 24h. NULL = never checked.
  lastFollowerCheckAt DateTime?
  // Same idea for the message-requests inbox: the "you have N message
  // requests" digest only counts requests that arrived since the user last
  // opened the Requests screen. NULL = never checked.
  lastRequestCheckAt  DateTime?
  availableFor  String[]  @default(["text"])
  availableUntil DateTime?
  isVerified    Boolean   @default(false)
  verifiedAt    DateTime?
  verifiedRole  String?
  // When set, this verification is time-limited (manual/admin grant) and the
  // verificationExpiry job auto-clears isVerified once it passes. NULL =
  // permanent (e.g. subscription-driven verification) — never auto-expired.
  verifiedUntil DateTime?
  isProfilePublic Boolean @default(true)
  hideOnlineStatus Boolean @default(false)
  hideReadReceipts Boolean @default(false)
  twoFactorSecret   String?
  twoFactorEnabled  Boolean @default(false)
  twoFactorRecovery String[]  @default([])
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  preference     UserPreference?
  moderation     UserModeration?
  subscription   Subscription?
  refreshTokens  RefreshToken[]
  devices        UserDevice[]
  aiSessions     AiSession[]
  matchRequests  MatchRequest[]
  conversations  ConversationParticipant[]
  messages       Message[]
  reportsMade    Report[]  @relation("ReportsMade")
  reportsAgainst Report[]  @relation("ReportsAgainst")
  blocksInitiated  Block[]  @relation("BlocksInitiated")
  blocksReceived   Block[]  @relation("BlocksReceived")
  followsInitiated Follow[] @relation("FollowsInitiated")
  followsReceived  Follow[] @relation("FollowsReceived")
  likesInitiated   Like[]   @relation("LikesInitiated")
  likesReceived    Like[]   @relation("LikesReceived")
  reactions        MessageReaction[]
  callLogs         CallLog[]
  spotlightLogs    SpotlightLog[]
  posts            Post[]
  postLikes        PostLike[]
  postBookmarks    PostBookmark[]
  postReactions    PostReaction[]
  postComments     PostComment[]
  commentReactions CommentReaction[]
  notifications    Notification[]
  fcmTokens        FcmToken[]
  voipTokens       VoipToken[]
  stories          Story[]
  storyHighlights  StoryHighlight[]
  storyViews       StoryView[]
  storySlideViews  StorySlideView[]
  storyReactions   StoryReaction[]
  storyBoosts      StoryBoost[]
  storyMutesInitiated StoryMute[] @relation("StoryMutesInitiated")
  storyMutesReceived  StoryMute[] @relation("StoryMutesReceived")
  storyHidesInitiated StoryHide[] @relation("StoryHidesInitiated")
  storyHidesReceived  StoryHide[] @relation("StoryHidesReceived")
  reels               Reel[]
  reelLikes           ReelLike[]
  reelComments        ReelComment[]
  reelReposts         ReelRepost[]
  reelViews           ReelView[]
  reelReactions       ReelReaction[]
  streaksAsA          MessageStreak[] @relation("StreakUserA")
  streaksAsB          MessageStreak[] @relation("StreakUserB")
  coinBalance      CoinBalance?
  coinTransactions CoinTransaction[]
  giftsSent        StoryGift[]    @relation("GiftsSent")
  giftsReceived    StoryGift[]    @relation("GiftsReceived")
  chatFolders      ChatFolder[]
  polls            Poll[]
  pollVotes        PollVote[]
  reEngagementPushes ReEngagementPush[]

  @@index([isOnline, lastSeenAt])
}

model UserModeration {
  id            String    @id @default(uuid())
  userId        String    @unique
  banStatus     BanStatus @default(NONE)
  banExpiresAt  DateTime?
  flagCount     Int       @default(0)
  lastFlaggedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([banStatus])
}

model Subscription {
  id         String   @id @default(uuid())
  userId     String   @unique
  externalId String?  // RevenueCat subscription ID
  status     String?  // "active", "cancelled", "past_due", "trialing"
  plan       String?  // "premium", "pro", etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id        String      @id @default(uuid())
  userId    String      @unique
  mood      MoodTag     @default(NEUTRAL)
  language  String      @default("en")
  timezone  String      @default("UTC")
  topics    String[]    @default([])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  token       String    @unique
  expiresAt   DateTime
  // Rotation tracking — when set, the token has been used and replaced.
  // Reuse of a revoked token indicates token theft (RFC 6819 §5.2.2.3).
  revokedAt   DateTime?
  replacedBy  String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SecurityAuditLog {
  id         String   @id @default(uuid())
  userId     String?
  event      String   // LOGIN_SUCCESS, LOGIN_FAILED, LOGOUT, PASSWORD_RESET, 2FA_ENABLED, etc.
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([event, createdAt])
}

model UserDevice {
  id           String   @id @default(uuid())
  userId       String
  fingerprint  String   // Hash of userAgent + ipCountry
  userAgent    String?
  ipCountry    String?
  ipAddress    String?
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
}

model OtpCode {
  id        String   @id @default(uuid())
  key       String   // phone number or "reset:<email>"
  code      String
  attempts  Int      @default(0)
  maxAttempts Int    @default(5)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([key])
  @@index([expiresAt])
}

model AiSession {
  id       String          @id @default(uuid())
  userId   String
  mode     CompanionMode
  status   AiSessionStatus @default(ACTIVE)
  metadata Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId, status])
}

model AiMessage {
  id        String        @id @default(uuid())
  sessionId String
  role      AiMessageRole
  content   String
  mood      MoodTag?
  metadata  Json?
  createdAt DateTime      @default(now())

  session AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model MatchRequest {
  id        String             @id @default(uuid())
  userId    String
  intent    MatchIntent
  mood      MoodTag            @default(NEUTRAL)
  language  String             @default("en")
  timezone  String             @default("UTC")
  topics    String[]           @default([])
  status    MatchRequestStatus @default(WAITING)
  matchedWith String?
  fromAiSession String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, intent])
  @@index([status, createdAt])
  @@index([userId])
}

/// Snap-style daily-message streak between two users. Canonical pairing:
/// userAId < userBId so each pair has exactly one row, regardless of who
/// sends first. The streak is "alive" while now - lastMutualDay <= 1 day;
/// no cron needed — display logic short-circuits to 0 once it lapses.
model MessageStreak {
  userAId               String
  userBId               String
  count                 Int      @default(0)
  lastMutualDay         DateTime?
  lastUserAMessageDay   DateTime?
  lastUserBMessageDay   DateTime?
  updatedAt             DateTime @updatedAt

  userA User @relation("StreakUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("StreakUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@id([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Conversation {
  id        String             @id @default(uuid())
  type      ConversationType   @default(HUMAN_MATCHED)
  status    ConversationStatus @default(ACTIVE)
  name        String?
  description String?
  avatarUrl   String?
  isPublic    Boolean            @default(true)
  isVerified  Boolean            @default(false)
  callsEnabled  Boolean          @default(true)
  videoEnabled  Boolean          @default(true)
  disappearAfterSecs Int?       // null=off, 86400=24h, 604800=7d, 2592000=30d
  inviteCode         String?    @unique
  isChannel          Boolean    @default(false)
  bannerUrl          String?
  category           String?
  contactEmail       String?
  contactPhone       String?
  websiteUrl         String?
  location           String?
  operatingHours     String?   // e.g. "Mon-Fri 9am-5pm"
  channelSourceId    String?    // For channel DMs: links to the channel conversation
  pinnedPostId       String?
  adminsOnlyMessages Boolean    @default(false)
  adminsOnlyEditInfo Boolean    @default(false)
  adminsOnlyAddMembers Boolean  @default(false)
  adminsOnlyLinks    Boolean    @default(false) // non-admins can't post URLs
  // Request flow for stranger DMs. requestStatus stays NULL for
  // existing conversations and group chats; only direct conversations
  // initiated by a non-follower flip to PENDING.
  requestStatus  ConversationRequestStatus?
  requestedById  String?
  acceptedAt     DateTime?
  declinedAt     DateTime?
  metadata  Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  archivedAt DateTime?

  participants ConversationParticipant[]
  messages     Message[]
  callLogs     CallLog[]
  posts        Post[]
  stories      Story[]
  polls        Poll[]
}

// ── Channel Posts ──

model Post {
  id            String    @id @default(uuid())
  channelId     String
  authorId      String
  content       String    @default("")
  mediaUrl      String?
  mediaType     String?   // "image", "video"
  thumbnailUrl  String?
  locationName  String?
  taggedUserIds String[]  @default([])
  musicTitle    String?
  musicArtist   String?
  musicPreviewUrl String?
  musicArtwork  String?
  commentsDisabled Boolean @default(false)
  hideLikeCount    Boolean @default(false)
  likeCount     Int       @default(0)
  commentCount  Int       @default(0)
  shareCount    Int       @default(0)
  viewCount     Int       @default(0)
  scheduledAt   DateTime?
  isPublished   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  channel  Conversation   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     PostLike[]
  bookmarks  PostBookmark[]
  reactions  PostReaction[]
  comments PostComment[]
  media    PostMedia[]

  @@index([channelId, createdAt])
  @@index([authorId])
}

model PostMedia {
  id            String   @id @default(uuid())
  postId        String
  type          String   // "IMAGE" or "VIDEO"
  url           String
  cloudinaryId  String   @default("")
  thumbnailUrl  String?
  caption       String?
  position      Int      @default(0)
  createdAt     DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, position])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model PostReaction {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  emoji     String   // 🔥 😂 😮 😢 😡 👏
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model PostBookmark {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  parentId  String?
  content   String
  likeCount Int      @default(0)
  createdAt DateTime @default(now())

  post    Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  PostComment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies PostComment[]  @relation("CommentReplies")
  reactions CommentReaction[]

  @@index([postId, createdAt])
  @@index([parentId])
}

model CommentReaction {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  emoji     String   // "like", "love", "laugh", "sad", "angry"
  createdAt DateTime @default(now())

  comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
}

model ConversationParticipant {
  id             String          @id @default(uuid())
  conversationId String
  userId         String
  role           ParticipantRole @default(MEMBER)
  lastReadAt      DateTime?
  lastDeliveredAt DateTime?
  joinedAt        DateTime        @default(now())
  leftAt         DateTime?
  isPinned       Boolean         @default(false)
  isMuted        Boolean         @default(false)
  mutedUntil     DateTime?
  isArchived     Boolean         @default(false)
  clearedAt      DateTime?
  bannedAt       DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String    @id @default(uuid())
  // Client-generated dedup key. The client generates a UUID at compose
  // time and sends it with the message; the server uses it as a unique
  // upsert key so a retried send (e.g. flaky network) doesn't create
  // a duplicate row. Nullable for backwards-compat with old clients.
  clientMsgId    String?   @unique
  conversationId String
  senderId       String
  content        String
  isSystem       Boolean   @default(false)
  metadata       Json?
  replyToId      String?
  imageUrl       String?
  // Multi-image album. Empty array = single-image (or non-image) message;
  // imageUrl is still mirrored to imageUrls[0] so old clients keep working.
  imageUrls      String[]  @default([])
  audioUrl       String?
  audioDuration  Int?
  // Set on first play by any recipient. Drives the WhatsApp-style
  // listened indicator: blue dot disappears on the receiver's bubble,
  // and the sender's mic icon turns blue once a recipient plays.
  // Set-once via the voice:played socket event; subsequent plays are
  // server-side idempotent (no overwrite once non-null).
  voicePlayedAt  DateTime?
  // Chat video attachment (R2-hosted .mp4). Thumbnail is generated
  // client-side at upload time (R2 doesn't auto-thumbnail like
  // Cloudinary) and uploaded alongside the video. Duration in seconds
  // is captured at the same time so the bubble can show the chip
  // without having to spin up a player.
  videoUrl           String?
  videoThumbnailUrl  String?
  videoDuration      Int?
  viewOnce       Boolean   @default(false)
  viewOnceOpened Boolean   @default(false)
  isPinned       Boolean   @default(false)
  pinnedAt       DateTime?
  pinnedById     String?
  editedAt       DateTime?
  deletedAt      DateTime?
  deletedFor     String[]   @default([])
  expiresAt      DateTime?  // set when disappearAfterSecs is active on conversation
  // Set true when scam detection flags this message (off-platform lure /
  // money ask) in a stranger/request context. Drives a client-side safety
  // banner shown ONLY to the recipient. Never blocks the send.
  scamWarning    Boolean   @default(false)
  createdAt      DateTime  @default(now())

  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?           @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]          @relation("MessageReplies")
  reactions    MessageReaction[]
  poll         Poll?

  @@index([conversationId, createdAt])
  @@index([conversationId, senderId, deletedAt, createdAt])
  @@index([senderId])
  @@index([replyToId])
  @@index([expiresAt])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Report {
  id          String             @id @default(uuid())
  reporterId  String
  reportedId  String
  reason      ReportReason
  details     String?
  // When the report targets a specific piece of content (not just the user).
  contentType ReportContentType?
  contentId   String?
  status      ReportStatus       @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  reporter User @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("ReportsAgainst", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId, status])
}

enum ReportContentType {
  STORY
  REEL
  POST
  MESSAGE
  COMMENT
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// Auto-generated flag when scam detection fires on a chat message. Feeds a
// future human review queue (query reviewed=false). Deliberately kept off
// the automated report/ban ladder — a keyword hit warns the recipient but
// must not by itself ban the sender (too false-positive-prone). Relation-less
// (plain IDs) on purpose: this is an internal audit log, not user-facing.
model ScamFlag {
  id             String   @id @default(uuid())
  senderId       String   // flagged sender (potential scammer)
  recipientId    String   // who received the message
  conversationId String
  messageId      String
  categories     String[] @default([]) // OFF_PLATFORM | MONEY | CONTACT
  snippet        String   // truncated excerpt of the offending text
  reviewed       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([senderId, createdAt])
  @@index([reviewed, createdAt])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("FollowsInitiated", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("FollowsReceived", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Like {
  id        String   @id @default(uuid())
  likerId   String
  likedId   String
  createdAt DateTime @default(now())

  liker User @relation("LikesInitiated", fields: [likerId], references: [id], onDelete: Cascade)
  liked User @relation("LikesReceived", fields: [likedId], references: [id], onDelete: Cascade)

  @@unique([likerId, likedId])
  @@index([likerId])
  @@index([likedId])
}

model CallLog {
  id             String        @id @default(uuid())
  callId         String        @unique
  conversationId String
  initiatorId    String
  callType       CallType      @default(AUDIO)
  status         CallLogStatus @default(MISSED)
  startedAt      DateTime      @default(now())
  endedAt        DateTime?
  durationSecs   Int?
  qualityRating  Int?          // 1-5 star rating submitted after the call
  qualityIssues  String[]      @default([])  // tags: "audio", "video", "connection", "other"

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  initiator    User         @relation(fields: [initiatorId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([initiatorId])
  @@index([conversationId, status, startedAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  imageUrl  String?
  data      Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   @default("android") // 'android' | 'ios'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VoipToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   // 'ios'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SpotlightLog {
  id            String    @id @default(uuid())
  broadcasterId String
  note          String?
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  peakViewers   Int       @default(0)
  totalViewers  Int       @default(0)
  connectCount  Int       @default(0)

  broadcaster User @relation(fields: [broadcasterId], references: [id], onDelete: Cascade)

  @@index([broadcasterId])
  @@index([startedAt])
}

enum StoryVisibility {
  FRIENDS
  PUBLIC
}

model Story {
  id          String          @id @default(uuid())
  userId      String
  channelId   String?
  createdAt   DateTime        @default(now())
  expiresAt   DateTime
  isPermanent Boolean         @default(false)
  visibility  StoryVisibility @default(FRIENDS)

  // Public engagement counters shown under each action icon in the
  // story viewer's right-side rail. Maintained by the story service:
  //   - likeCount    bumped by likeStory (+1 on like, -1 on unlike)
  //   - commentCount bumped by replyToStory (+1 per reply)
  //   - repostCount  bumped by the repost endpoint
  //   - shareCount   bumped when the user opens the system share sheet
  //   - downloadCount bumped when the user saves the slide to gallery
  // Denormalized on the row so the feed query stays one read; the
  // canonical source-of-truth tables (StoryReaction, Message, etc.)
  // still exist if a backfill is ever needed.
  likeCount     Int @default(0)
  commentCount  Int @default(0)
  repostCount   Int @default(0)
  shareCount    Int @default(0)
  downloadCount Int @default(0)

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Conversation? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  slides  StorySlide[]
  views   StoryView[]
  boosts  StoryBoost[]
  gifts   StoryGift[]
  reactions StoryReaction[]

  @@index([userId, expiresAt])
  @@index([channelId, expiresAt])
  @@index([expiresAt])
  @@index([visibility, expiresAt])
}

model StoryBoost {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  tier      String   @default("basic") // basic, premium
  startedAt DateTime @default(now())
  expiresAt DateTime
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@index([userId])
  @@index([expiresAt])
}

model CoinBalance {
  id      String @id @default(uuid())
  userId  String @unique
  balance Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoinTransaction {
  id             String          @id @default(uuid())
  userId         String
  amount         Int
  type           TransactionType
  relatedStoryId String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model StoryGift {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  storyId     String
  giftType    String   // heart, star, diamond, crown
  coinAmount  Int
  createdAt   DateTime @default(now())

  sender    User  @relation("GiftsSent", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User  @relation("GiftsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  story     Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([recipientId])
  @@index([storyId])
}

model StorySlide {
  id           String         @id @default(uuid())
  storyId      String
  type         StorySlideType @default(IMAGE)
  mediaUrl     String
  cloudinaryId String
  thumbnailUrl String?
  caption      String?
  duration     Int?
  position     Int            @default(0)
  metadata     Json?
  createdAt    DateTime       @default(now())

  story Story            @relation(fields: [storyId], references: [id], onDelete: Cascade)
  views StorySlideView[]

  @@index([storyId])
}

/// Per-slide view tracking (Instagram-style): one row per viewer per slide,
/// so each slide in a story has its own view count and viewer list. This is
/// separate from StoryView, which stays story-level and continues to power
/// the unviewed ring, the "viewed your story" notification, and milestones.
model StorySlideView {
  id        String   @id @default(uuid())
  slideId   String
  viewerId  String
  isStealth Boolean  @default(false)
  createdAt DateTime @default(now())

  slide  StorySlide @relation(fields: [slideId], references: [id], onDelete: Cascade)
  viewer User       @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([slideId, viewerId])
  @@index([slideId])
  @@index([viewerId])
}

/// A user's permanent collection of saved story slides.
/// Slides are *copied* from StorySlide at add-time so the highlight
/// outlives the original story's 24h expiry.
model StoryHighlight {
  id        String   @id @default(uuid())
  userId    String
  title     String
  coverUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  slides StoryHighlightSlide[]

  @@index([userId, createdAt])
}

model StoryHighlightSlide {
  id           String         @id @default(uuid())
  highlightId  String
  type         StorySlideType @default(IMAGE)
  mediaUrl     String
  thumbnailUrl String?
  caption      String?
  duration     Int?
  position     Int            @default(0)
  createdAt    DateTime       @default(now())

  highlight StoryHighlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  @@index([highlightId, position])
}

model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  viewerId  String
  liked     Boolean  @default(false)
  isStealth Boolean  @default(false)
  createdAt DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer User  @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([storyId, viewerId])
  @@index([storyId])
  @@index([viewerId])
}

model StoryReaction {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
  @@index([userId])
}

model Reel {
  id           String   @id @default(uuid())
  userId       String
  videoUrl     String
  cloudinaryId String?
  thumbnailUrl String?
  caption      String?
  musicTitle       String?
  // iTunes 30-sec preview URL — frontend AudioPlayer plays this under
  // the active reel. Mirrors the music attachment used by stories.
  musicPreviewUrl  String?
  musicArtist      String?
  musicArtwork     String?
  // Mix levels 0..1 the creator picked in the editor. Null = use the
  // legacy default ("music replaces video": video volume 0, music 1).
  // Both columns are nullable so existing reels keep working.
  videoVolume      Float?
  musicVolume      Float?
  durationSec  Int?
  viewCount    Int      @default(0)
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  createdAt    DateTime @default(now())

  repostCount Int @default(0)
  /// Per-reel viewer-side video edits (filter / overlays / speed) stored
  /// as JSON. Applied at playback by the FE — no server bake.
  videoEdits  Json?

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     ReelLike[]
  comments  ReelComment[]
  reposts   ReelRepost[]
  views     ReelView[]
  reactions ReelReaction[]

  @@index([userId, createdAt])
  @@index([createdAt])
}

model ReelReaction {
  id        String   @id @default(uuid())
  reelId    String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
  @@index([reelId])
  @@index([userId])
}

model ReelLike {
  id        String   @id @default(uuid())
  reelId    String
  userId    String
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
  @@index([reelId])
  @@index([userId])
}

model ReelComment {
  id        String   @id @default(uuid())
  reelId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reelId, createdAt])
  @@index([userId])
}

model ReelRepost {
  id        String   @id @default(uuid())
  reelId    String
  userId    String
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
  @@index([userId, createdAt])
  @@index([reelId])
}

model ReelView {
  id          String   @id @default(uuid())
  reelId      String
  userId      String
  viewedAt    DateTime @default(now())
  watchedSec  Int      @default(0)
  completed   Boolean  @default(false)

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
  @@index([userId, viewedAt])
  @@index([reelId])
}

model StoryMute {
  id          String   @id @default(uuid())
  muterId     String
  mutedUserId String
  createdAt   DateTime @default(now())

  muter     User @relation("StoryMutesInitiated", fields: [muterId], references: [id], onDelete: Cascade)
  mutedUser User @relation("StoryMutesReceived", fields: [mutedUserId], references: [id], onDelete: Cascade)

  @@unique([muterId, mutedUserId])
  @@index([muterId])
  @@index([mutedUserId])
}

// A story OWNER hides their stories from a specific viewer (inverse of
// StoryMute). The owner's stories are excluded from the hidden viewer's
// feeds. Reversible from the owner's "Hidden from your story" list.
model StoryHide {
  id           String   @id @default(uuid())
  ownerId      String
  hiddenUserId String
  createdAt    DateTime @default(now())

  owner      User @relation("StoryHidesInitiated", fields: [ownerId], references: [id], onDelete: Cascade)
  hiddenUser User @relation("StoryHidesReceived", fields: [hiddenUserId], references: [id], onDelete: Cascade)

  @@unique([ownerId, hiddenUserId])
  @@index([ownerId])
  @@index([hiddenUserId])
}

// ─── Chat Folders ──────────────────────────────────────

model ChatFolder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  icon      String?  // emoji or icon name
  color     String?  // hex color e.g. "#E3F2FD"
  position  Int      @default(0)
  createdAt DateTime @default(now())

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  members ChatFolderMember[]

  @@index([userId, position])
}

model ChatFolderMember {
  id             String @id @default(uuid())
  folderId       String
  conversationId String

  folder ChatFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, conversationId])
  @@unique([conversationId]) // one folder per conversation
  @@index([folderId])
}

// ── Polls ──

model Poll {
  id             String       @id @default(uuid())
  conversationId String
  messageId      String       @unique
  creatorId      String
  question       String
  allowMultiple  Boolean      @default(false)
  closedAt       DateTime?
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  options      PollOption[]
  votes        PollVote[]

  @@index([conversationId, createdAt])
}

model PollOption {
  id       String     @id @default(uuid())
  pollId   String
  text     String
  orderIdx Int

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId, orderIdx])
}

model PollVote {
  id        String     @id @default(uuid())
  pollId    String
  optionId  String
  voterId   String
  createdAt DateTime   @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voter  User       @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([optionId, voterId])
  @@index([pollId])
  @@index([voterId])
}

// ── Admin (internal dashboard) ──

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  READ_ONLY
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  displayName  String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([role, isActive])
}

// Log of re-engagement pushes sent to dormant users so the campaign
// cron can dedupe per cadence step. Unique on (userId, cadenceDay)
// guarantees each step (3 / 7 / 14 / 30 days inactive) fires at most
// once per user, ever — clean enough for MVP without needing a
// "dormant spell" concept yet.
model ReEngagementPush {
  id         String           @id @default(uuid())
  userId     String
  cadenceDay Int
  hookType   ReEngagementHook
  sentAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cadenceDay])
  @@index([sentAt])
}

enum AnnouncementSeverity {
  INFO
  WARNING
  CRITICAL
}

// App-wide announcements (maintenance notices, outages, "update required").
// The client fetches the single active one within its time window on launch /
// foreground, and also receives a socket `announcement` event when an admin
// publishes one for instant display. Dismissals are tracked client-side per id.
model Announcement {
  id          String               @id @default(uuid())
  title       String
  body        String
  severity    AnnouncementSeverity @default(INFO)
  active      Boolean              @default(true)
  dismissible Boolean              @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  ctaText     String?
  ctaUrl      String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([active, startsAt, endsAt])
}

/// Append-only audit trail of legal-document acceptances. One row per time a
/// user agrees to the current Terms / Privacy / Community Guidelines version
/// (onboarding and any later re-consent), for legal proof.
model LegalConsent {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version    Int
  acceptedAt DateTime @default(now())
  platform   String?
  appVersion String?

  @@index([userId])
}
